# Supabase (Dashboard → Settings → API)
# Publishable (anon): se usa en toda la app con la sesión del usuario (RLS).
NEXT_PUBLIC_SUPABASE_URL=https://yfkmtrcpbdwwmnfeawva.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-publishable-anon-key

# Secret: solo para Auth Admin (crear admin, crear/eliminar profesores, resetear contraseña).
# Opcional si no usás scripts/create-admin.js ni panel de profesores.
SUPABASE_SECRET_KEY=your-secret-key
# SUPABASE_SERVICE_ROLE_KEY=...  # alias legacy; SUPABASE_SECRET_KEY tiene prioridad

# Conexión directa PostgreSQL (migraciones, seeds, psql, GUI)
# Sustituir [YOUR-PASSWORD] por la contraseña de la base de datos
# DATABASE_URL=postgresql://postgres:[YOUR-PASSWORD]@db.yfkmtrcpbdwwmnfeawva.supabase.co:5432/postgres

# Opcional: para generar tipos TypeScript desde el schema
# SUPABASE_PROJECT_ID=yfkmtrcpbdwwmnfeawva

# Zona horaria para fechas/horas de clases (creación, listado público, QR). Por defecto America/Argentina/Buenos_Aires.
# NEXT_PUBLIC_APP_TIMEZONE=America/Argentina/Buenos_Aires

# Si es "true" o "1", los alumnos que se registran por link/QR se aprueban automáticamente (active). Si no existe, quedan pendientes (to_confirm).
# AUTO_APPROVE_QR_STUDENTS=true

# Usuario admin (node scripts/create-admin.js)
# ADMIN_EMAIL=admin@test.com
# ADMIN_PASSWORD=Admin123!
